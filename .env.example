# Copy this file to .env.local for local development
# On Vercel, set these in Project Settings → Environment Variables

# Supabase (필수 - 통계 저장용)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google AdSense (선택 - AdSense 승인 후 설정)
# 형식: ca-pub-XXXXXXXXXXXXXXXX (16자리 숫자)
# 승인 전에는 공백으로 두세요 (placeholder 광고 슬롯 표시)
# 설정하면 자동으로:
#  1. <head>에 AdSense loader 스크립트 삽입
#  2. /ads.txt 자동 생성 (google.com, pub-XXX, DIRECT, f08c47fec0942fa0)
#  3. AdSlot 컴포넌트가 실제 광고로 전환
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Google Search Console 사이트 소유권 검증 (선택)
# https://search.google.com/search-console → Add Property → HTML Tag 방식 선택
# → 받은 content 값(예: "abc123...")만 여기에 입력
# → 배포 후 Search Console에서 "Verify" 클릭
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics (선택)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
